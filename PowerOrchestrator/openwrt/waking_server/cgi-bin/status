#!/bin/sh
# =============================================================================
# OpenWrt Waking Server CGI Status Endpoint (Upgraded & Secure)
# File: /www_waking/cgi-bin/status
# =============================================================================

# Print HTTP headers
echo "Content-Type: application/json"
echo "Cache-Control: no-cache"
echo ""

CONF="/etc/homelab_power.conf"
if [ ! -f "$CONF" ]; then
    echo '{"status": "error", "message": "Config not found"}'
    exit 0
fi

. "$CONF"

# Load messages config
MSG_CONF="/etc/homelab_messages.conf"
if [ -f "$MSG_CONF" ]; then
    . "$MSG_CONF"
fi

# Set default values if not defined
[ -z "$PRIVATE_SUBNETS" ] && PRIVATE_SUBNETS="192.168.11.0/24,100.64.0.0/10,127.0.0.1/32"
[ -z "$ENABLE_PORT_WAKE_LISTENERS" ] && ENABLE_PORT_WAKE_LISTENERS="0"

# --- Native IP CIDR Subnet Match Helpers ---
ip_to_int() {
    local o1 o2 o3 o4
    IFS=. read -r o1 o2 o3 o4 <<EOF
$1
EOF
    echo "$(( (o1 << 24) + (o2 << 16) + (o3 << 8) + o4 ))"
}

ip_in_subnet() {
    local ip="$1"
    local subnet="$2"
    local sub_ip=$(echo "$subnet" | cut -d'/' -f1)
    local mask=$(echo "$subnet" | cut -d'/' -f2 -s)
    [ -z "$mask" ] && mask=32
    
    local ip_int=$(ip_to_int "$ip")
    local sub_int=$(ip_to_int "$sub_ip")
    
    # Avoid bitwise shift error by 32 in standard shell
    local mask_int=0
    if [ "$mask" -eq 0 ]; then
        mask_int=0
    else
        mask_int=$(( 0xFFFFFFFF << (32 - mask) ))
    fi
    
    local result=$(( (ip_int & mask_int) == (sub_int & mask_int) ))
    return $(( ! result ))
}

REAL_PEER_IP="${REMOTE_ADDR:-127.0.0.1}"
is_private_network() {
    for range in $(echo "$PRIVATE_SUBNETS" | tr ',' ' '); do
        if ip_in_subnet "$REAL_PEER_IP" "$range"; then
            return 0
        fi
    done
    return 1
}

# Robust Busybox-native URL decoder using AWK
url_decode() {
    echo "$1" | awk '
    BEGIN {
        for (i=0; i<256; i++) {
            char = sprintf("%c", i)
            hex = sprintf("%02x", i)
            hexcodes[hex] = char
            hexcodes[toupper(hex)] = char
        }
    }
    {
        gsub(/\+/, " ")
        while (match($0, /%[0-9A-Fa-f]{2}/)) {
            code = substr($0, RSTART+1, 2)
            $0 = substr($0, 1, RSTART-1) hexcodes[code] substr($0, RSTART+3)
        }
        print $0
    }'
}

# Helper to escape values for safe JSON transmission
escape_json() {
    echo "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

# Extract true Client IP (handles proxies like Tailscale Funnel)
CLIENT_IP="${REMOTE_ADDR:-127.0.0.1}"
if [ -n "$HTTP_X_FORWARDED_FOR" ]; then
    CLIENT_IP=$(echo "$HTTP_X_FORWARDED_FOR" | cut -d',' -f1 | tr -d ' ')
elif [ -n "$HTTP_X_REAL_IP" ]; then
    CLIENT_IP="$HTTP_X_REAL_IP"
fi

# Parse query string parameters (vmid, service, name, code, portal_code, and trigger)
VMID_RAW=$(echo "$QUERY_STRING" | tr '&' '\n' | grep -iE "^(vmid|service|name)=" | cut -d'=' -f2- 2>/dev/null)
VMID=$(url_decode "$VMID_RAW" | tr 'A-Z' 'a-z')
CODE_RAW=$(echo "$QUERY_STRING" | tr '&' '\n' | grep -E "^code=" | cut -d'=' -f2- 2>/dev/null)
PORTAL_CODE_RAW=$(echo "$QUERY_STRING" | tr '&' '\n' | grep -E "^portal_code=" | cut -d'=' -f2- 2>/dev/null)
TRIGGER=$(echo "$QUERY_STRING" | tr '&' '\n' | grep -E "^trigger=" | cut -d'=' -f2- 2>/dev/null)

CODE=$(url_decode "$CODE_RAW")
PORTAL_CODE=$(url_decode "$PORTAL_CODE_RAW")

# --- DDoS Guard & Rate Limiter ---
RATE_DIR="/tmp/status_rate_limit"
mkdir -p "$RATE_DIR"
# Safe file name from IP
IP_FILE="${RATE_DIR}/$(echo "$CLIENT_IP" | tr -cd 'a-zA-Z0-9.')"

CURRENT_TIME=$(date +%s)
LAST_REQ=0
if [ -f "$IP_FILE" ]; then
    LAST_REQ=$(cat "$IP_FILE")
fi

# Check if we should bypass the DDoS Guard rate limit
BYPASS_RATE_LIMIT=0
if [ "$TRIGGER" = "1" ] || [ -n "$CODE_RAW" ] || [ -n "$PORTAL_CODE_RAW" ]; then
    # Bypass for active user interactions (entering codes or waking up)
    BYPASS_RATE_LIMIT=1
fi
if is_private_network; then
    # Bypass completely for local private network users
    BYPASS_RATE_LIMIT=1
fi

if [ "$BYPASS_RATE_LIMIT" -eq 0 ]; then
    # Enforce 3 seconds cooldown between status queries for untrusted scrapers
    ELAPSED_REQ=$((CURRENT_TIME - LAST_REQ))
    if [ "$ELAPSED_REQ" -lt 3 ]; then
        echo '{"status": "blocked", "message": "DDoS Guard: Too many requests. Please wait."}'
        exit 0
    fi
fi
echo "$CURRENT_TIME" > "$IP_FILE"

# --- Centralized Notification Helper (Async) ---
notify() {
    /usr/bin/homelab_notify.sh "$1" &
}

# --- Rate-Limit / Global WoL Cooldown Lock ---
enforce_wol_cooldown() {
    local lock_file="/tmp/wol_cooldown_lock"
    local cooldown=60
    if [ -f "$lock_file" ]; then
        local last_wol=$(cat "$lock_file")
        local diff=$((CURRENT_TIME - last_wol))
        if [ "$diff" -lt "$cooldown" ]; then
            local remain=$((cooldown - diff))
            echo "{\"status\": \"cooldown\", \"message\": \"WoL cooldown active. Please wait ${remain}s before retrying.\"}"
            exit 0
        fi
    fi
    echo "$CURRENT_TIME" > "$lock_file"
}

# Translate friendly name to numeric VMID using GUEST_NAME_MAP if non-numeric
if [ -n "$VMID" ] && ! echo "$VMID" | grep -qE "^[0-9]+$"; then
    FOUND_VMID=$(echo "$GUEST_NAME_MAP" | tr ',' '\n' | while read -r mapping; do
        id=$(echo "$mapping" | cut -d':' -f1)
        name=$(echo "$mapping" | cut -d':' -f2 | tr 'A-Z' 'a-z')
        if [ "$name" = "$VMID" ]; then
            echo "$id"
            break
        fi
    done)
    if [ -n "$FOUND_VMID" ]; then
        VMID="$FOUND_VMID"
    fi
fi

# Strictly validate that VMID is numeric
if [ -n "$VMID" ] && ! echo "$VMID" | grep -qE "^[0-9]+$"; then
    echo "{\"status\": \"error\", \"message\": \"Invalid VMID format\"}"
    exit 0
fi

# --- Portal Gatekeeper Authenticator ---
IS_FUNNEL_REQUEST=0
# If the request comes through Tailscale Funnel, it is SNI-proxied from the public internet (port 443/80),
# meaning uhttpd receives it with a Host header that does NOT contain the direct local ports (:8080 or :8443).
if ! echo "$HTTP_HOST" | grep -qE "(:8080|:8443)"; then
    IS_FUNNEL_REQUEST=1
fi

USER_IS_PRIVATE=0
if [ "$IS_FUNNEL_REQUEST" -eq 0 ] && is_private_network; then
    USER_IS_PRIVATE=1
fi

PORTAL_LOCKED=0
REQUIRED_PORTAL_CODE=""
if [ "$USER_IS_PRIVATE" -eq 1 ]; then
    REQUIRED_PORTAL_CODE="$PORTAL_PRIVATE_PASSCODE"
else
    REQUIRED_PORTAL_CODE="$PORTAL_FUNNEL_PASSCODE"
fi

if [ -n "$REQUIRED_PORTAL_CODE" ]; then
    if [ "$PORTAL_CODE" != "$REQUIRED_PORTAL_CODE" ]; then
        PORTAL_LOCKED=1
    fi
fi

if [ "$PORTAL_LOCKED" -eq 1 ]; then
    echo "{\"status\": \"portal_locked\", \"is_private\": ${USER_IS_PRIVATE}}"
    exit 0
fi

# --- General Host check helper ---
is_host_online() {
    if ping -c 1 -W 1 "$HOST_IP" >/dev/null 2>&1; then
        return 0
    fi
    for p in 8006 80 8123 22; do
        if nc -w 1 -z "$HOST_IP" "$p" >/dev/null 2>&1; then
            return 0
        fi
    done
    return 1
}

# =============================================================================
# MULTI-TENANT DIRECTORY DASHBOARD MODE (No specific VMID requested)
# =============================================================================
if [ -z "$VMID" ]; then
    HOST_STATUS="sleeping"
    if is_host_online; then
        HOST_STATUS="online"
    fi
    
    # Parse guest_codes (Format: vmid:code,vmid:code)
    GUEST_CODES_RAW=$(echo "$QUERY_STRING" | tr '&' '\n' | grep -E "^guest_codes=" | cut -d'=' -f2- 2>/dev/null)
    GUEST_CODES=$(url_decode "$GUEST_CODES_RAW")
    
    local metrics=""
    local cpu=""
    local ram_used=""
    local ram_total=""
    local temp=""
    local disk=""
    
    if [ "$HOST_STATUS" = "online" ]; then
        CACHE_FILE="/tmp/homelab_metrics_cache"
        CACHE_VALID=0
        if [ -f "$CACHE_FILE" ]; then
            local now=$(date +%s)
            local cache_time=$(head -n 1 "$CACHE_FILE" 2>/dev/null)
            if echo "$cache_time" | grep -qE "^[0-9]+$"; then
                if [ $((now - cache_time)) -lt 10 ]; then
                    metrics=$(tail -n +2 "$CACHE_FILE" 2>/dev/null)
                    CACHE_VALID=1
                fi
            fi
        fi
        
        if [ "$CACHE_VALID" -eq 0 ]; then
            metrics=$($SSH_CMD "cpu=\$(grep 'cpu ' /proc/stat | awk '{usage=(\$2+\$4)*100/(\$2+\$4+\$5)} END {printf \"%.1f\", usage}'); ram=\$(free -m | awk 'NR==2 {printf \"%d:%d\", \$3, \$2}'); temp=\$(for z in /sys/class/thermal/thermal_zone*; do [ -f \"\$z/temp\" ] && read -r t < \"\$z/temp\" && read -r y < \"\$z/type\" && echo \"\$y:\$t\" || true; done | grep -iE 'pkg|cpu|soc' | head -n 1 | cut -d: -f2); [ -z \"\$temp\" ] && temp=\$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null); [ -z \"\$temp\" ] && temp=0; temp=\$((temp/1000)); disk=\$(df -h / | awk 'NR==2 {print \$5}' | tr -d '%'); echo \"\$cpu|\$ram|\$temp|\$disk\"" 2>/dev/null)
            if [ -n "$metrics" ]; then
                (echo "$(date +%s)"; echo "$metrics") > "$CACHE_FILE"
            fi
        fi
        
        if [ -n "$metrics" ]; then
            cpu=$(echo "$metrics" | cut -d'|' -f1)
            local ram_raw=$(echo "$metrics" | cut -d'|' -f2)
            temp=$(echo "$metrics" | cut -d'|' -f3)
            disk=$(echo "$metrics" | cut -d'|' -f4)
            
            ram_used=$(echo "$ram_raw" | cut -d':' -f1)
            ram_total=$(echo "$ram_raw" | cut -d':' -f2)
        fi
    fi
    
    echo "{"
    echo "  \"status\": \"online\","
    echo "  \"is_private\": ${USER_IS_PRIVATE},"
    if [ "$HOST_STATUS" = "online" ] && [ -n "$cpu" ]; then
        echo "  \"host\": {\"status\": \"${HOST_STATUS}\", \"ip\": \"${HOST_IP}\", \"cpu\": ${cpu}, \"ram_used\": ${ram_used}, \"ram_total\": ${ram_total}, \"temp\": ${temp}, \"disk\": ${disk}},"
    else
        echo "  \"host\": {\"status\": \"${HOST_STATUS}\", \"ip\": \"${HOST_IP}\"},"
    fi
    echo "  \"guests\": ["
    
    # Pre-ping all guests in parallel to avoid sequential delay bottleneck
    if [ "$HOST_STATUS" = "online" ]; then
        for entry in $(echo "$GUEST_ORCHESTRATION_MAP" | tr ',' ' '); do
            g_vmid=$(echo "$entry" | cut -d':' -f1)
            g_ip=$(echo "$entry" | cut -d':' -f2)
            if [ -n "$g_ip" ]; then
                (
                    if ping -c 1 -W 1 "$g_ip" >/dev/null 2>&1; then
                        echo "1" > "/tmp/ping_vmid_${g_vmid}"
                    else
                        echo "0" > "/tmp/ping_vmid_${g_vmid}"
                    fi
                ) &
            fi
        done
        wait
    fi
    
    # Loop through configured guest map
    first=1
    for entry in $(echo "$GUEST_ORCHESTRATION_MAP" | tr ',' ' '); do
        g_vmid=$(echo "$entry" | cut -d':' -f1)
        g_ip=$(echo "$entry" | cut -d':' -f2)
        
        # Privacy filter
        g_privacy=$(echo "$GUEST_PRIVACY_MAP" | grep -oE "${g_vmid}:[^,]+" | cut -d':' -f2 2>/dev/null)
        [ -z "$g_privacy" ] && g_privacy="private" # Default to private-only
        
        if [ "$USER_IS_PRIVATE" -eq 0 ] && [ "$g_privacy" != "public" ]; then
            # Friends cannot see private guests
            continue
        fi
        
        g_name=$(echo "$GUEST_NAME_MAP" | grep -oE "${g_vmid}:[^,]+" | cut -d':' -f2 2>/dev/null)
        [ -z "$g_name" ] && g_name="Guest ${g_vmid}"
        g_name_escaped=$(escape_json "$g_name")
        
        g_port=$(echo "$GUEST_PORT_MAP" | grep -oE "${g_vmid}:[^,]+" | cut -d':' -f2 2>/dev/null)
        [ -z "$g_port" ] && g_port=""
        
        g_online=0
        if [ "$HOST_STATUS" = "online" ]; then
            if [ -f "/tmp/ping_vmid_${g_vmid}" ]; then
                g_online=$(cat "/tmp/ping_vmid_${g_vmid}")
                rm -f "/tmp/ping_vmid_${g_vmid}"
            else
                if ping -c 1 -W 1 "$g_ip" >/dev/null 2>&1; then
                    g_online=1
                fi
            fi
        fi
        
        g_passcode=$(echo "$GUEST_PASSCODE_MAP" | grep -oE "${g_vmid}:[^,]+" | cut -d':' -f2 2>/dev/null)
        g_passcode_req="true"
        [ -z "$g_passcode" ] && g_passcode_req="false"
        
        # Extract guest code sent by client
        g_client_code=$(echo "$GUEST_CODES" | tr ',' '\n' | grep -E "^${g_vmid}:" | cut -d':' -f2- 2>/dev/null)
        
        g_verified=0
        if [ "$g_passcode_req" = "false" ] || [ "$USER_IS_PRIVATE" -eq 1 ]; then
            g_verified=1
        elif [ -n "$g_client_code" ] && [ "$g_client_code" = "$g_passcode" ]; then
            g_verified=1
        fi
        
        g_msg=""
        if [ "$g_verified" -eq 1 ]; then
            g_msg=$(echo "$GUEST_MESSAGE_MAP" | grep -oE "${g_vmid}:[^,]+" | cut -d':' -f2- 2>/dev/null)
        fi
        g_msg_escaped=$(escape_json "$g_msg")
        
        if [ "$first" -eq 0 ]; then
            echo ","
        fi
        first=0
        
        g_status="sleeping"
        if [ "$g_online" -eq 1 ]; then
            g_status="online"
        elif [ -f "/tmp/waking_vmid_${g_vmid}" ]; then
            WAKE_TIME=$(cat "/tmp/waking_vmid_${g_vmid}")
            if [ $((CURRENT_TIME - WAKE_TIME)) -lt 90 ]; then
                g_status="waking"
            else
                rm -f "/tmp/waking_vmid_${g_vmid}"
            fi
        fi
        
        echo -n "    {\"vmid\": \"${g_vmid}\", \"name\": \"${g_name_escaped}\", \"status\": \"${g_status}\", \"passcode_required\": ${g_passcode_req}, \"message\": \"${g_msg_escaped}\", \"port\": \"${g_port}\", \"ip\": \"${g_ip}\"}"
    done
    
    echo ""
    echo "  ]"
    echo "}"
    exit 0
fi

# =============================================================================
# SINGLE GUEST WAKING MODE
# =============================================================================
GUEST_NAME=$(echo "$GUEST_NAME_MAP" | grep -oE "${VMID}:[^,]+" | cut -d':' -f2 2>/dev/null)
[ -z "$GUEST_NAME" ] && GUEST_NAME="Guest $VMID"
GUEST_NAME_ESCAPED=$(escape_json "$GUEST_NAME")

GUEST_PORT=$(echo "$GUEST_PORT_MAP" | grep -oE "${VMID}:[^,]+" | cut -d':' -f2 2>/dev/null)
[ -z "$GUEST_PORT" ] && GUEST_PORT=""

TARGET_PASSCODE=$(echo "$GUEST_PASSCODE_MAP" | grep -oE "${VMID}:[^,]+" | cut -d':' -f2 2>/dev/null)
PASSCODE_REQUIRED="true"
[ -z "$TARGET_PASSCODE" ] && PASSCODE_REQUIRED="false"

GUEST_MESSAGE=$(echo "$GUEST_MESSAGE_MAP" | grep -oE "${VMID}:[^,]+" | cut -d':' -f2- 2>/dev/null)
GUEST_MESSAGE_ESCAPED=$(escape_json "$GUEST_MESSAGE")
GUEST_IP=$(echo "$GUEST_ORCHESTRATION_MAP" | grep -oE "${VMID}:[^:]+" | cut -d':' -f2 2>/dev/null)

GUEST_ONLINE=0
if is_host_online && [ -n "$GUEST_IP" ]; then
    if ping -c 1 -W 1 "$GUEST_IP" >/dev/null 2>&1; then
        GUEST_ONLINE=1
    fi
fi

# 1. Passcode Lock Check
PASS_VERIFIED=0
if [ "$PASSCODE_REQUIRED" = "false" ] || [ "$USER_IS_PRIVATE" -eq 1 ]; then
    # Bypass passcode if none configured or if user is on private network
    PASS_VERIFIED=1
elif [ -n "$CODE" ] && [ "$CODE" = "$TARGET_PASSCODE" ]; then
    PASS_VERIFIED=1
fi

if [ "$PASS_VERIFIED" -eq 0 ] && [ -n "$CODE" ]; then
    # Incorrect passcode submitted
    echo "{\"status\": \"unauthorized\", \"message\": \"Invalid passcode\", \"name\": \"$GUEST_NAME_ESCAPED\", \"vmid\": \"$VMID\", \"passcode_required\": true, \"port\": \"$GUEST_PORT\", \"ip\": \"$GUEST_IP\"}"
    exit 0
fi

# Check if boot sequence is actively in progress
GUEST_WAKING=0
if [ -f "/tmp/waking_vmid_${VMID}" ]; then
    WAKE_TIME=$(cat "/tmp/waking_vmid_${VMID}")
    if [ $((CURRENT_TIME - WAKE_TIME)) -lt 90 ]; then
        GUEST_WAKING=1
    else
        rm -f "/tmp/waking_vmid_${VMID}"
    fi
fi

# 2. Return Status and only return sensitive messages if verified
if [ "$PASS_VERIFIED" -eq 0 ]; then
    echo "{\"status\": \"sleeping\", \"name\": \"$GUEST_NAME_ESCAPED\", \"vmid\": \"$VMID\", \"passcode_required\": true, \"passcode_verified\": false, \"message\": \"\", \"port\": \"$GUEST_PORT\", \"ip\": \"$GUEST_IP\"}"
    exit 0
fi

# 3. Code verified! Return status and handle wake triggers
if [ "$GUEST_ONLINE" -eq 1 ]; then
    rm -f "/tmp/waking_vmid_${VMID}"
    echo "{\"status\": \"online\", \"name\": \"$GUEST_NAME_ESCAPED\", \"vmid\": \"$VMID\", \"passcode_required\": ${PASSCODE_REQUIRED}, \"passcode_verified\": true, \"message\": \"$GUEST_MESSAGE_ESCAPED\", \"port\": \"$GUEST_PORT\", \"ip\": \"$GUEST_IP\"}"
    exit 0
fi

# If actively waking and trigger not requested (or already triggered), bypass execution
if [ "$GUEST_WAKING" -eq 1 ]; then
    echo "{\"status\": \"waking\", \"name\": \"$GUEST_NAME_ESCAPED\", \"vmid\": \"$VMID\", \"passcode_required\": ${PASSCODE_REQUIRED}, \"passcode_verified\": true, \"message\": \"$GUEST_MESSAGE_ESCAPED\", \"port\": \"$GUEST_PORT\", \"ip\": \"$GUEST_IP\"}"
    exit 0
fi

# 4. Guest is offline (sleeping). If trigger=1 is not requested, return sleeping but with verified details
if [ "$TRIGGER" != "1" ]; then
    echo "{\"status\": \"sleeping\", \"name\": \"$GUEST_NAME_ESCAPED\", \"vmid\": \"$VMID\", \"passcode_required\": ${PASSCODE_REQUIRED}, \"passcode_verified\": true, \"message\": \"$GUEST_MESSAGE_ESCAPED\", \"port\": \"$GUEST_PORT\", \"ip\": \"$GUEST_IP\"}"
    exit 0
fi

# 5. Guest is offline and trigger=1 requested: Wake it up!
enforce_wol_cooldown

# Mark as waking
echo "$CURRENT_TIME" > "/tmp/waking_vmid_${VMID}"

# Log notifications
if ! is_host_online; then
    notify "$(eval echo "\"$MSG_WEB_WAKE_GUEST_WAKING_HOST\"")"
else
    notify "$(eval echo "\"$MSG_WEB_WAKE_GUEST\"")"
fi

# WOL Host
etherwake -i br-lan "$HOST_MAC" >/dev/null 2>&1

# Asynchronous Guest Resume Loop
SSH_KEY_PATH="/etc/dropbear/id_dropbear"
SSH_CMD="ssh -i $SSH_KEY_PATH -y -K 3 root@$HOST_IP"

(
    while true; do
        if is_host_online; then
            break
        fi
        sleep 2
    done
    
    $SSH_CMD "if pct config $VMID >/dev/null 2>&1; then 
                pct resume $VMID >/dev/null 2>&1 || pct start $VMID >/dev/null 2>&1
              elif qm config $VMID >/dev/null 2>&1; then 
                qm resume $VMID >/dev/null 2>&1 || qm start $VMID >/dev/null 2>&1
              fi" >/dev/null 2>&1
              
    if [ -n "$GUEST_IP" ]; then
        max_retries=60
        while [ $max_retries -gt 0 ]; do
            if ping -c 1 -W 1 "$GUEST_IP" >/dev/null 2>&1; then
                rm -f "/tmp/waking_vmid_${VMID}"
                notify "$(eval echo "\"$MSG_WEB_GUEST_AWAKE\"")"
                break
            fi
            sleep 5
            max_retries=$((max_retries - 1))
        done
    fi
    rm -f "/tmp/waking_vmid_${VMID}"
) >/dev/null 2>&1 </dev/null &

echo "{\"status\": \"waking\", \"name\": \"$GUEST_NAME_ESCAPED\", \"vmid\": \"$VMID\", \"passcode_required\": ${PASSCODE_REQUIRED}, \"passcode_verified\": true, \"message\": \"$GUEST_MESSAGE_ESCAPED\", \"port\": \"$GUEST_PORT\", \"ip\": \"$GUEST_IP\"}"
exit 0
