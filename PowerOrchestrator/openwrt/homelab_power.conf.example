# =============================================================================
# OpenWrt Homelab Power Orchestrator Configuration (Template)
# File: /etc/homelab_power.conf
# =============================================================================

# --- Telegram Bot Credentials ---
# Telegram Bot API Token obtained from @BotFather
BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"

# Comma-separated list of allowed Telegram user IDs that are authorized to run control commands
# e.g. "8881234,9994321". Get yours via @userinfobot or @GetMyIDBot
ALLOWED_USER_IDS="YOUR_TELEGRAM_USER_ID"

# Optional Target Telegram Chat ID for all wake notifications (can be a user ID or group chat ID).
# If empty, defaults to the first ID in ALLOWED_USER_IDS. Group IDs typically start with a minus sign (e.g. -100123456).
NOTIFY_CHAT_ID=""

# --- Target Host Configuration ---
# The IP address of the Proxmox VE host
HOST_IP="192.168.11.10"

# The physical MAC address of the Proxmox VE host (used for Wake-on-LAN)
HOST_MAC="aa:bb:cc:dd:ee:ff"

# Path to the Dropbear/OpenSSH private key used for passwordless SSH access to Proxmox
SSH_KEY_PATH="/etc/dropbear/id_dropbear"

# --- Network Wake-on-Demand Ports ---
# Comma-separated list of HTTP TCP ports on the Proxmox host that should be intercepted 
# and redirected to the beautiful local waking page (port 8080) when Proxmox is sleeping.
HTTP_REDIRECT_PORTS="80,8123"

# Comma-separated list of HTTPS TCP ports on the Proxmox host that should be intercepted
# and redirected to the local waking page over SSL (port 8443) when Proxmox is sleeping.
# Common: 443, 8006 (Proxmox UI)
HTTPS_REDIRECT_PORTS="443,8006"

# Comma-separated list of game ports that should run local wake listeners when Proxmox
# is sleeping. When a client tries to connect, it triggers a wake-on-LAN immediately.
# Syntax: Add '/udp' suffix for UDP ports. Defaults to TCP if no suffix is specified.
# Common: 
# - 25565: Minecraft Java (TCP)
# - 19132/udp: Minecraft Bedrock (UDP)
# - 27015/udp,27016/udp: Unturned Steam Server (UDP query and game ports)
GAME_REDIRECT_PORTS="25565,19132/udp,27015/udp,27016/udp"


# --- Orchestration Daemon Tuning ---
# Interval in seconds to check if the Proxmox host is alive (ping)
CHECK_INTERVAL="5"

# Number of consecutive ping failures before declaring the host is asleep (S3)
PING_RETRIES="3"

# --- Multi-Guest Dynamic Orchestration Map ---
# Comma-separated list of individual VMs/LXCs that should auto-sleep/wake dynamically.
# Format: "VMID:IP_ADDRESS:PORT/PROTOCOL:IDLE_MINUTES"
# Must match the settings configured in Proxmox /etc/homelab_power.conf.
# Example: "101:192.168.11.50:25565/tcp:15,102:192.168.11.60:19132/udp:15"
# Leave empty if not using individual guest sleep/wake orchestration.
GUEST_ORCHESTRATION_MAP=""

# --- Safe Shutdown / Reboot Exemptions ---
# Comma-separated list of VMIDs that represent "always running" core services (e.g. NAS, Nginx, Pihole).
# These guests will NOT statically block `/hostshutdown` or `/hostreboot` from the Telegram bot.
# The host will still safely verify that these instances are NOT actively in use (CPU, Network Rate, Ports)
# on Proxmox before shutting down!
EXEMPT_SHUTDOWN_GUESTS=""

# --- Waking Web Server Security ---
# Passcode required on the Glassmorphic waking screen to allow Wake-on-LAN commands.
# This prevents unauthorized visitors (from public Tailscale Funnel) from waking your homelab.
WAKE_PASSCODE="YOUR_SECURE_PASSCODE"

# --- Two-Tier Portal Access Passcodes ---
# Passcode required to unlock and display the main Unified Dashboard itself.
# Leave PORTAL_PRIVATE_PASSCODE blank to give private network instant passcode-free access inside the LAN/Tailscale.
PORTAL_FUNNEL_PASSCODE="YOUR_FUNNEL_PORTAL_PASSCODE"
PORTAL_PRIVATE_PASSCODE=""

# --- Privacy Subnets & Filters ---
# Subnets that represent your secure private/admin network (LAN and Tailscale range).
# Clients connecting from outside these ranges (e.g. friends over external links) will have private guests hidden.
PRIVATE_SUBNETS="192.168.11.0/24,100.64.0.0/10"

# Mappings of Guest VMIDs to their privacy level: 'public' (visible to everyone) or 'private' (visible only to private network).
GUEST_PRIVACY_MAP="120:private,122:public"

# --- Anti-Accidental Wake Port Listeners ---
# Enable or disable the raw TCP/UDP port Wake-on-Demand listeners on the router.
# Set to "0" (Recommended) to prevent background internet port scans or client server list pings from waking guests.
# If "0", guests are safely woken ONLY via the secure Web Page or Telegram Bot.
ENABLE_PORT_WAKE_LISTENERS="0"

# --- Discord Webhook Notifications (Optional) ---
# Generate a webhook URL in your Discord App Channel settings to send rich status embeds.
# e.g., "https://discord.com/api/webhooks/123456789/abcdefgh"
DISCORD_WEBHOOK_URL=""

# --- Multi-Tenant Guest Waking Security & Naming Maps ---
# Mappings of Guest VMIDs to their specific friendly names and access passcodes.
# The Waking Web Server is fully generic and automatically adapts to any service defined here!
# For example, adding "125:Valheim" to GUEST_NAME_MAP and "125:odinpass" to GUEST_PASSCODE_MAP
# will instantly make http://router/?service=valheim (or ?vmid=125) render a customized
# "Valheim Verification" page prompting for "odinpass", with ZERO code changes!
# Format: "VMID:VALUE,VMID:VALUE"
GUEST_NAME_MAP="120:Minecraft,122:Unturned"
GUEST_PASSCODE_MAP="120:mcpass,122:unturnedpass"
GUEST_MESSAGE_MAP="120:Welcome to Minecraft!,122:Welcome to Unturned!"

# Mappings of Guest VMIDs to their custom Web Interface redirect ports.
# If configured, clicking 'Open Web Interface' will dynamically redirect to this port.
# Format: "VMID:PORT,VMID:PORT"
# Leave blank or omit for standard name-based fallback matching or port-free requests.
GUEST_PORT_MAP=""





